{
  "extends": [
    "config:best-practices"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "labels": ["patch", "renovate-deps"]
  },
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "packageRules": [
    {
      "depTypeList": [
        "devDependencies"
      ],
      "excludePackageNames": [
        "@vercel/ncc",
        "typescript"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "labels": [
        "no release",
        "renovate-deps"
      ],
      "automerge": true
    },
    {
      "depTypeList": [
        "devDependencies"
      ],
      "matchPackageNames": [
        "typescript"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "labels": [
        "no release",
        "renovate-deps"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "pin",
        "pinDigest"
      ],
      "minimumReleaseAge": null,
      "automerge": true
    },
    {
      "groupName": "dependencies",
      "matchUpdateTypes": ["major"],
      "matchDepTypes": ["dependencies"],
      "labels": ["minor", "renovate-deps"]
    },
    {
      "groupName": "dependencies",
      "matchUpdateTypes": ["patch", "minor"],
      "matchDepTypes": ["dependencies"],
      "labels": ["patch", "renovate-deps"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchPackageNames": ["@vercel/ncc"],
      "labels": ["patch", "renovate-deps"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "labels": ["no release", "renovate-deps"],
      "automerge": true,
      "matchPackageNames": ["!@vercel/ncc", "!typescript"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["patch"],
      "labels": ["no release", "renovate-deps"],
      "automerge": true
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["minor"],
      "labels": ["no release", "renovate-deps"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["major"],
      "labels": ["patch", "renovate-deps"]
    }
  ],
  "github-actions": {
    "enabled": true,
    "labels": ["no release", "renovate-deps"],
    "automerge": true
  },
  "minimumReleaseAge": "30 days"
}
